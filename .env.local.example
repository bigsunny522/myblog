# Notion Integration
# Copy this file to .env.local and fill in your values.

# Notion Internal Integration Token
# https://www.notion.so/my-integrations で取得
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID
# データベースページのURLから取得: notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
# "?" より前の32文字がDatabase ID
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AdSense Publisher ID
# https://adsense.google.com で取得 (形式: ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
